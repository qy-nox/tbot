# ═══════════════════════════════════════════════════════════════════════
# tbot - Complete Trading Signal Ecosystem Configuration
# ═══════════════════════════════════════════════════════════════════════

# ────────────────────────────────────────────────────────────────────────
# 1. EXCHANGE API (Binance)
# ────────────────────────────────────────────────────────────────────────
BINANCE_API_KEY=your_binance_api_key
BINANCE_API_SECRET=your_binance_api_secret
EXCHANGE_ID=binance

# ────────────────────────────────────────────────────────────────────────
# 2. NEWS API (Finnhub)
# ────────────────────────────────────────────────────────────────────────
FINNHUB_API_KEY=your_finnhub_api_key

# ────────────────────────────────────────────────────────────────────────
# 3. TELEGRAM BOT TOKENS (Get from @BotFather)
# ────────────────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_BOT_TOKEN_MAIN=your_main_bot_token
TELEGRAM_BOT_TOKEN_SUB=your_subscription_bot_token
TELEGRAM_BOT_TOKEN_ADMIN=your_admin_bot_token
BOT1_SUBSCRIPTION_TOKEN=your_subscription_bot_token
BOT2_ADMIN_TOKEN=your_admin_bot_token
BOT3_DISTRIBUTION_TOKEN=your_distribution_bot_token

# ────────────────────────────────────────────────────────────────────────
# 4. ADMIN CONFIGURATION
# ────────────────────────────────────────────────────────────────────────
ADMIN_IDS=123456789

# ────────────────────────────────────────────────────────────────────────
# 5. TELEGRAM CHANNEL CONFIGURATION
# ────────────────────────────────────────────────────────────────────────
TELEGRAM_CHAT_ID=your_telegram_chat_id
BROADCAST_TELEGRAM_CHANNELS=-1001234567890,-1009876543210
CRYPTO_SIGNAL_CH1=-1001234567890
CRYPTO_SIGNAL_CH2=
CRYPTO_SIGNAL_CH3=
BINARY_SIGNAL_CH1=-1002345678901
BINARY_SIGNAL_CH2=
BINARY_SIGNAL_CH3=
DEMO_TRADING_CHANNEL=-1003456789012
ADMIN_CHANNEL=-1004567890123

# ────────────────────────────────────────────────────────────────────────
# 6. DISCORD (Optional)
# ────────────────────────────────────────────────────────────────────────
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/1234567890/xxxxxxxxxxxxxxxxxxxx

# ────────────────────────────────────────────────────────────────────────
# 7. EMAIL CONFIGURATION (SMTP)
# ────────────────────────────────────────────────────────────────────────
EMAIL_FROM=signals@tradingbot.com
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password

# ────────────────────────────────────────────────────────────────────────
# 8. DATABASE
# ───────────────────────────────────────────────────────────────���────────
DATABASE_URL=sqlite:///trading_bot.db

# ────────────────────────────────────────────────────────────────────────
# 9. JWT & AUTHENTICATION
# ────────────────────────────────────────────────────────────────────────
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production_12345678
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=30

# ────────────────────────────────────────────────────────────────────────
# 10. API SERVER
# ────────────────────────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
DASHBOARD_PORT=8000
DASHBOARD_HOST=0.0.0.0

# ────────────────────────────────────────────────────────────────────────
# 11. TRADING CONFIGURATION
# ────────────────────────────────────────────────────────────────────────
TRADING_MODE=paper
INITIAL_CAPITAL=10000.0
RISK_PER_TRADE=0.02
MAX_OPEN_TRADES=5
MAX_DRAWDOWN=0.10

# ────────────────────────────────────────────────────────────────────────
# 12. BOT BEHAVIOR
# ────────────────────────────────────────────────────────────────────────
BOT_POLLING=True
BOT_WEBHOOK=False
SCAN_INTERVAL_SECONDS=300
LOG_LEVEL=INFO

# ────────────────────────────────────────────────────────────────────────
# 13. PAYMENT PROCESSING
# ────────────────────────────────────────────────────────────────────────
PAYMENT_PROVIDER=stripe
PAYMENT_TIMEOUT_SECONDS=1800
STRIPE_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxx
STRIPE_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxxxxxxxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxx
PAYPAL_CLIENT_ID=xxxxxxxxxxxxxxxxxxxx
PAYPAL_CLIENT_SECRET=xxxxxxxxxxxxxxxxxxxx
PAYPAL_API_MODE=sandbox

# ────────────────────────────────────────────────────────────────────────
# 14. SUBSCRIPTION PLANS
# ────────────────────────────────────────────────────────────────────────
FREE_PLAN_SIGNALS=5
PREMIUM_PLAN_SIGNALS=20
VIP_PLAN_SIGNALS=-1
PREMIUM_PLAN_PRICE=29.99
VIP_PLAN_PRICE=79.99

# ────────────────────────────────────────────────────────────────────────
# 15. NOTIFICATION SETTINGS
# ────────────────────────────────────────────────────────────────────────
NOTIFY_ON_SIGNAL=True
NOTIFY_ON_PAYMENT=True
NOTIFY_ON_SUBSCRIPTION_EXPIRY=True
SUBSCRIPTION_EXPIRY_NOTICE_DAYS=2

# ────────────────────────────────────────────────────────────────────────
# 16. ML & AI CONFIGURATION
# ────────────────────────────────────────────────────────────────────────
ML_ENABLED=True
ML_TRAINING_CANDLES=500
ML_PREDICTION_HORIZON=5
ML_MODEL_PATH=models/ensemble.pkl

# ────────────────────────────────────────────────────────────────────────
# 17. MARKET DATA SETTINGS
# ────────────────────────────────────────────────────────────────────────
MARKET_UPDATE_INTERVAL=30
PRICE_DECIMAL_PLACES=2
VOLUME_DECIMAL_PLACES=0

# ────────────────────────────────────────────────────────────────────────
# 18. DEMO TRADING
# ────────────────────────────────────────────────────────────────────────
DEMO_INITIAL_BALANCE=10000.0
DEMO_ENABLED=True
DEMO_COMMISSION=0.001

# ────────────────────────────────────────────────────────────────────────
# 19. SECURITY
# ────────────────────────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:3000,http://localhost:8000
SECRET_KEY=your_secret_key_here_change_in_production
ALLOWED_HOSTS=localhost,127.0.0.1,your-domain.com

# ────────────────────────────────────────────────────────────────────────
# 20. WEBHOOK URLS
# ────────────────────────────────────────────────────────────────────────
WEBHOOK_HOST=https://your-domain.com
WEBHOOK_PORT=8000
PAYMENT_WEBHOOK_URL=https://your-domain.com/webhook/payment
SIGNAL_WEBHOOK_URL=https://your-domain.com/webhook/signal

# ────────────────��───────────────────────────────────────────────────────
# 21. REDIS (Optional - for caching)
# ────────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
REDIS_ENABLED=False

# ────────────────────────────────────────────────────────────────────────
# 22. LOGGING
# ────────────────────────────────────────────────────────────────────────
LOG_DIR=logs
LOG_FILE=trading_bot.log
LOG_MAX_BYTES=10485760
LOG_BACKUP_COUNT=5
LOG_FORMAT=%(asctime)s - %(name)s - %(levelname)s - %(message)s

# ────────────────────────────────────────────────────────────────────────
# 23. DEVELOPMENT & TESTING
# ────────────────────────────────────────────────────────────────────────
DEBUG=False
ENVIRONMENT=production
TEST_MODE=False

# ────────────────────────────────────────────────────────────────────────
# 24. RATE LIMITING
# ────────────────────────────────────────────────────────────────────────
RATE_LIMIT_ENABLED=True
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_PERIOD=60

# ────────────────────────────────────────────────────────────────────────
# 25. TIMEOUT SETTINGS
# ────────────────────────────────────────────────────────────────────────
API_TIMEOUT=30
DATABASE_TIMEOUT=30
TELEGRAM_TIMEOUT=30
