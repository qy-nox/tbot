REFRESH_TOKEN_EXPIRE_DAYS=30

# ────────────────────────────────────────────────────────────────────────
# 10. API SERVER
# ────────────────────────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
# Optional: when true, start_api will terminate processes using API_PORT before boot.
API_FORCE_KILL_PORT=False
DASHBOARD_PORT=8000
DASHBOARD_HOST=0.0.0.0

# ────────────────────────────────────────────────────────────────────────
# 11. TRADING CONFIGURATION
# ────────────────────────────────────────────────────────────────────────
TRADING_MODE=paper
INITIAL_CAPITAL=10000.0
RISK_PER_TRADE=0.02
MAX_OPEN_TRADES=5
MAX_DRAWDOWN=0.10

# ────────────────────────────────────────────────────────────────────────
# 12. BOT BEHAVIOR
# ────────────────────────────────────────────────────────────────────────
BOT_POLLING=True
BOT_WEBHOOK=False
SCAN_INTERVAL_SECONDS=300
LOG_LEVEL=INFO

# ────────────────────────────────────────────────────────────────────────
# 13. PAYMENT PROCESSING
# ────────────────────────────────────────────────────────────────────────
PAYMENT_PROVIDER=stripe
PAYMENT_TIMEOUT_SECONDS=1800
STRIPE_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxx
STRIPE_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxxxxxxxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxx
PAYPAL_CLIENT_ID=xxxxxxxxxxxxxxxxxxxx
PAYPAL_CLIENT_SECRET=xxxxxxxxxxxxxxxxxxxx
PAYPAL_API_MODE=sandbox

# ────────────────────────────────────────────────────────────────────────
# 14. SUBSCRIPTION PLANS
# ────────────────────────────────────────────────────────────────────────
FREE_PLAN_SIGNALS=5
PREMIUM_PLAN_SIGNALS=20
VIP_PLAN_SIGNALS=-1
PREMIUM_PLAN_PRICE=29.99
VIP_PLAN_PRICE=79.99

# ────────────────────────────────────────────────────────────────────────
# 15. NOTIFICATION SETTINGS
# ────────────────────────────────────────────────────────────────────────
NOTIFY_ON_SIGNAL=True
NOTIFY_ON_PAYMENT=True
NOTIFY_ON_SUBSCRIPTION_EXPIRY=True
